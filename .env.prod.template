# ================================================================
# 프로덕션 환경 변수 템플릿
# 실제 배포 시 .env.prod 로 복사 후 모든 값을 채워주세요
# ⚠️  .env.prod 는 절대 git에 커밋하지 마세요 (.gitignore 적용됨)
# ================================================================

# ───────────────────────────────────────
# AWS RDS 프로덕션 DB 설정 (별도 서버)
# ───────────────────────────────────────
AWS_PROD_DB_URL=jdbc:postgresql://<prod-rds-endpoint>:5432/<prod-database>
AWS_PROD_DB_USERNAME=<prod_db_user>
AWS_PROD_DB_PASSWORD=<prod_db_password>

# ───────────────────────────────────────
# Spring 프로파일
# ───────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# ───────────────────────────────────────
# API JWT 시크릿 (HMAC-SHA256)
# ⚠️  반드시 32자 이상의 랜덤 문자열로 변경 (openssl rand -hex 32)
# ───────────────────────────────────────
JWT_SECRET=<replace-with-openssl-rand-hex-32-output>
JWT_EXPIRATION_MS=86400000

# ───────────────────────────────────────
# OAuth2 RSA 키스토어 (entrypoint.sh 자동 생성)
# ───────────────────────────────────────
JWT_KEYSTORE_LOCATION=classpath:keys/keystore.p12
JWT_KEYSTORE_PASSWORD=<secure_keystore_password>
JWT_KEYSTORE_ALIAS=oauth-key

KEYSTORE_PATH=/workspace/src/main/resources/keys/keystore.p12
KEY_ALIAS=oauth-key
KEYSTORE_PW=<secure_keystore_password>
DNAME=CN=wordle-auth, OU=Prod, O=Wordle, L=Seoul, S=Seoul, C=KR

# ───────────────────────────────────────
# CORS — 실제 서비스 도메인으로 변경
# ───────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ───────────────────────────────────────
# 로깅 (프로덕션: WARN 이상만)
# ───────────────────────────────────────
LOGGING_LEVEL_ROOT=WARN

# ───────────────────────────────────────
# AWS 설정
# ───────────────────────────────────────
AWS_REGION=ap-northeast-2

# ───────────────────────────────────────
# Frontend (Next.js) 설정
# ───────────────────────────────────────
# 브라우저에서 백엔드 API를 호출할 공개 URL
NEXT_PUBLIC_API_URL=https://your-domain.com
FRONTEND_PORT=3000
