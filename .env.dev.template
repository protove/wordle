# ================================================================
# 개발 환경 변수 템플릿
# 실제 사용시 .env.dev 로 복사 후 값을 채워주세요
# ⚠️  .env.dev 는 절대 git에 커밋하지 마세요 (.gitignore 적용됨)
# ================================================================

# ───────────────────────────────────────
# AWS RDS 개발 DB 설정
# ───────────────────────────────────────
AWS_DEV_DB_URL=jdbc:postgresql://<dev-rds-endpoint>:5432/<dev-database>
AWS_DEV_DB_USERNAME=<dev_db_user>
AWS_DEV_DB_PASSWORD=<dev_db_password>

# ───────────────────────────────────────
# Spring 프로파일
# ───────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# ───────────────────────────────────────
# API JWT 시크릿 (HMAC-SHA256)
# ⚠️  프로덕션과 다른 키를 사용할 것을 권장 (openssl rand -hex 32)
# ───────────────────────────────────────
JWT_SECRET=your-dev-secret-key-min-32-characters-long-change-me
JWT_EXPIRATION_MS=86400000

# ───────────────────────────────────────
# CORS — 개발: localhost 허용
# ───────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ───────────────────────────────────────
# 로깅 (개발: INFO, 더 상세하게 보려면 DEBUG)
# ───────────────────────────────────────
LOGGING_LEVEL_ROOT=INFO

# ───────────────────────────────────────
# AWS 설정
# ───────────────────────────────────────
AWS_REGION=ap-northeast-2

# ───────────────────────────────────────
# Frontend (Next.js) 설정
# ───────────────────────────────────────
# 브라우저에서 백엔드 API를 호출할 주소
NEXT_PUBLIC_API_URL=http://localhost:8080
FRONTEND_PORT=3000
