# ================================================================
# 테스트 환경 변수 템플릿
# DEV와 같은 AWS RDS 서버를 사용하되 별도 데이터베이스 사용
# 실제 사용시 .env.test 로 복사 후 값을 채워주세요
# ⚠️  .env.test 는 절대 git에 커밋하지 마세요 (.gitignore 적용됨)
# ================================================================

# ───────────────────────────────────────
# AWS RDS 테스트 DB 설정 (DEV와 같은 서버, 다른 DB명)
# ───────────────────────────────────────
AWS_TEST_DB_URL=jdbc:postgresql://<dev-rds-endpoint>:5432/<test-database>
AWS_TEST_DB_USERNAME=<test_db_user>
AWS_TEST_DB_PASSWORD=<test_db_password>

# ───────────────────────────────────────
# Spring 프로파일
# ───────────────────────────────────────
SPRING_PROFILES_ACTIVE=test
SERVER_PORT=8080

# ───────────────────────────────────────
# API JWT 시크릿 (HMAC-SHA256)
# ───────────────────────────────────────
JWT_SECRET=your-test-secret-key-min-32-characters-long-change-me
JWT_EXPIRATION_MS=86400000

# ───────────────────────────────────────
# OAuth2 RSA 키스토어 (entrypoint.sh 자동 생성)
# ───────────────────────────────────────
JWT_KEYSTORE_LOCATION=classpath:keys/keystore.p12
JWT_KEYSTORE_PASSWORD=changeit
JWT_KEYSTORE_ALIAS=oauth-key

KEYSTORE_PATH=/workspace/src/main/resources/keys/keystore.p12
KEY_ALIAS=oauth-key
KEYSTORE_PW=changeit
DNAME=CN=wordle-auth, OU=Test, O=Wordle, L=Seoul, S=Seoul, C=KR

# ───────────────────────────────────────
# CORS — 테스트: localhost 허용
# ───────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ───────────────────────────────────────
# 로깅 (테스트: DEBUG)
# ───────────────────────────────────────
LOGGING_LEVEL_ROOT=INFO

# ───────────────────────────────────────
# AWS 설정
# ───────────────────────────────────────
AWS_REGION=ap-northeast-2

# ───────────────────────────────────────
# Frontend (Next.js) 설정
# ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
FRONTEND_PORT=3000
